{
  "manifest_version": 3,
  "name": "LinkedIn Search Multiplex",
  "version": "1.0.0",
  "description": "Run and aggregate multiple LinkedIn queries sequentially in a side-panel recruiter dashboard.",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {}
}
